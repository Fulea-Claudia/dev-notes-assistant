{
    "defaultMode": "default",
    "permissions": {
        "bash": {
            "allow": [
                "Bash(npm run dev)",
                "Bash(npm install)",
                "Bash(git status)"
            ],
            "deny": [
                "Bash(git push)",
                "Bash(git reset --hard)",
                "Bash(rm -rf)"
            ]
        }
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path' | xargs npx prettier --write"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
                    }
                ]
            }
        ]
    }
}